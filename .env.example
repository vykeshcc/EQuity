# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Gemini
GEMINI_API_KEY=
GEMINI_EXTRACTION_MODEL=gemini-2.5-pro
GEMINI_HARD_MODEL=gemini-2.5-pro

# Embeddings (Voyage for domain-tuned bio/sci embeddings; fallback: OpenAI)
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3-large
OPENAI_API_KEY=

# Ingestion
PUBMED_API_KEY=
PUBMED_EMAIL=
CRON_SECRET=

# Feature flags
ENABLE_AUTO_INGEST=true
