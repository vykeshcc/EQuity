# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Google Gemini
GOOGLE_API_KEY=
GEMINI_FLASH_MODEL=gemini-2.0-flash
GEMINI_PRO_MODEL=gemini-2.0-flash-thinking-exp

# Embeddings (Voyage for domain-tuned bio/sci embeddings; fallback: OpenAI)
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3-large
OPENAI_API_KEY=

# Ingestion
PUBMED_API_KEY=
PUBMED_EMAIL=
CRON_SECRET=

# Site
NEXT_PUBLIC_SITE_URL=https://equity.research

# Feature flags
ENABLE_AUTO_INGEST=true
